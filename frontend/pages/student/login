<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>edunova - Smart Learning Login</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"/>

  <script src="https://cdn.tailwindcss.com"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: "#5B34F2",
            primaryDark: "#4B22E8",
            bgSoft: "#F6F4FF",
            textDark: "#0C122D",
            textGray: "#5E657A",
            borderSoft: "#E6E8F0",
          },
          fontFamily: {
            inter: ["Inter", "sans-serif"],
          },
          boxShadow: {
            card: "0 2px 10px rgba(0,0,0,0.04)",
          }
        }
      }
    }
  </script>
</head>

<body class="bg-[#f4f2ff] font-inter">

  <div class="w-full min-h-screen p-[6px]">
    
    <div class="w-full min-h-[1000px] rounded-[28px] bg-[#F8F6FF] border border-[#E8E5F8] overflow-hidden">
      
      <div class="grid grid-cols-[46%_54%] h-full">

        <!-- LEFT SIDE -->
        <div class="relative px-[48px] pt-[46px] overflow-hidden">

          <!-- logo -->
          <div class="flex items-center gap-4">
            <div class="w-[54px] h-[54px] rounded-xl bg-gradient-to-br from-[#6D3BFF] to-[#4B22E8] flex items-center justify-center text-white text-[28px] shadow-lg">
              <i class="fa-solid fa-graduation-cap"></i>
            </div>

            <div class="text-[26px] font-[800] leading-none">
              <span class="text-[#5B34F2]">Edunova </span>
              <span class="text-[#111827]">- Smart Learning</span>
            </div>
          </div>

          <!-- hero -->
          <div class="mt-[72px] relative z-10">
            <h1 class="text-[72px] leading-[78px] font-[800] tracking-[-2px] text-[#09122D]">
              Welcome
              <span class="text-[#5B34F2]">Back!</span>
            </h1>

            <p class="mt-[20px] text-[23px] leading-[40px] text-[#5D647B] font-[500] max-w-[520px]">
              Login to continue your learning journey
              and achieve your goals.
            </p>

            <!-- features -->
            <div class="mt-[50px] flex flex-col gap-[30px]">

              <!-- item -->
              <div class="flex items-start gap-[26px]">
                <div class="w-[76px] h-[76px] rounded-[20px] bg-[#F0EAFF] border border-[#E4DAFF] flex items-center justify-center shadow-sm">
                  <i class="fa-solid fa-book-open text-[34px] text-[#5B34F2]"></i>
                </div>

                <div>
                  <h3 class="text-[18px] font-[700] text-[#141B34]">
                    Access Quality Courses
                  </h3>

                  <p class="mt-[6px] text-[16px] leading-[30px] text-[#555F76] max-w-[360px]">
                    Learn from expert instructors and
                    explore a wide range of courses.
                  </p>
                </div>
              </div>

              <!-- item -->
              <div class="flex items-start gap-[26px]">
                <div class="w-[76px] h-[76px] rounded-[20px] bg-[#F0EAFF] border border-[#E4DAFF] flex items-center justify-center shadow-sm">
                  <i class="fa-solid fa-chart-column text-[34px] text-[#5B34F2]"></i>
                </div>

                <div>
                  <h3 class="text-[18px] font-[700] text-[#141B34]">
                    Track Your Progress
                  </h3>

                  <p class="mt-[6px] text-[16px] leading-[30px] text-[#555F76] max-w-[360px]">
                    Monitor your learning progress
                    and improve your skills.
                  </p>
                </div>
              </div>

              <!-- item -->
              <div class="flex items-start gap-[26px]">
                <div class="w-[76px] h-[76px] rounded-[20px] bg-[#F0EAFF] border border-[#E4DAFF] flex items-center justify-center shadow-sm">
                  <i class="fa-solid fa-file-lines text-[34px] text-[#5B34F2]"></i>
                </div>

                <div>
                  <h3 class="text-[18px] font-[700] text-[#141B34]">
                    Earn Certificates
                  </h3>

                  <p class="mt-[6px] text-[16px] leading-[30px] text-[#555F76] max-w-[360px]">
                    Complete courses and earn
                    certificates to boost your career.
                  </p>
                </div>
              </div>

            </div>
          </div>

          <!-- background shape -->
          <div class="absolute left-[380px] top-[300px] w-[520px] h-[520px] rounded-full bg-[#EDE6FF] opacity-90"></div>

          <!-- dots -->
          <div class="absolute left-[550px] top-[440px] grid grid-cols-4 gap-[10px] opacity-60">
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>

            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>

            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>

            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
            <span class="w-[8px] h-[8px] rounded-full bg-[#D6C8FF]"></span>
          </div>

          <!-- illustration -->
          <div class="absolute bottom-[36px] left-[10px] w-[760px] z-20">

            <div class="relative">

              <!-- books -->
              <div class="absolute left-[0px] bottom-[16px]">
                <div class="w-[120px] h-[28px] rounded-[8px] bg-[#7A4CFF] shadow-md rotate-[-2deg]"></div>
                <div class="w-[130px] h-[30px] rounded-[8px] bg-[#5C7CFF] mt-[-4px] shadow-md rotate-[1deg]"></div>
                <div class="w-[140px] h-[30px] rounded-[8px] bg-[#95A7FF] mt-[-4px] shadow-md rotate-[-1deg]"></div>
              </div>

              <!-- plant -->
              <div class="absolute left-[42px] bottom-[120px]">
                <div class="relative w-[50px] h-[90px]">
                  <div class="absolute left-[18px] top-[0px] w-[18px] h-[55px] rounded-full bg-[#5FAE4E] rotate-[-15deg]"></div>
                  <div class="absolute left-[0px] top-[22px] w-[20px] h-[52px] rounded-full bg-[#6CC75D] rotate-[15deg]"></div>
                  <div class="absolute left-[28px] top-[26px] w-[18px] h-[48px] rounded-full bg-[#5FAE4E] rotate-[15deg]"></div>
                  <div class="absolute left-[10px] bottom-[0px] w-[42px] h-[34px] bg-white rounded-b-[14px] shadow-md border border-[#e8e8e8]"></div>
                </div>
              </div>

              <!-- laptop -->
              <div class="relative ml-[120px]">
                <div class="w-[470px] h-[300px] rounded-[18px] bg-[#0F172A] border-[10px] border-[#2E3347] shadow-2xl overflow-hidden">
                  
                  <!-- laptop screen -->
                  <div class="bg-white h-full p-[18px]">

                    <div class="flex justify-between items-center">
                      <div>
                        <div class="text-[15px] font-[700] text-[#141B34]">
                          Hello, Student!
                        </div>
                        <div class="text-[10px] text-[#8B92A8] mt-[2px]">
                          Let's continue learning.
                        </div>
                      </div>

                      <div class="w-[18px] h-[18px] rounded-full bg-[#D7E1FF]"></div>
                    </div>

                    <div class="grid grid-cols-3 gap-[12px] mt-[18px]">
                      <div class="bg-[#F7F8FC] rounded-xl p-[12px]">
                        <div class="text-[9px] text-[#8D95A8]">Courses Enrolled</div>
                        <div class="mt-[6px] text-[32px] font-[800] text-[#5B34F2]">12</div>
                      </div>

                      <div class="bg-[#F7F8FC] rounded-xl p-[12px]">
                        <div class="text-[9px] text-[#8D95A8]">Courses Taken</div>
                        <div class="mt-[6px] text-[32px] font-[800] text-[#7A4CFF]">08</div>
                      </div>

                      <div class="bg-[#F7F8FC] rounded-xl p-[12px]">
                        <div class="text-[9px] text-[#8D95A8]">Certificates</div>
                        <div class="mt-[6px] text-[32px] font-[800] text-[#111827]">05</div>
                      </div>
                    </div>

                    <div class="flex justify-between items-end mt-[34px]">

                      <div>
                        <div class="text-[12px] font-[700] text-[#111827]">
                          My Progress
                        </div>

                        <div class="flex items-center gap-[18px] mt-[18px]">
                          <div class="w-[72px] h-[72px] rounded-full border-[8px] border-[#EAE5FF] border-t-[#6B3CFF] rotate-45"></div>

                          <div>
                            <div class="text-[11px] text-[#111827] font-[600]">
                              You are doing great!
                            </div>

                            <div class="text-[10px] text-[#8D95A8] mt-[5px]">
                              Keep it up and achieve more.
                            </div>

                            <button class="mt-[12px] h-[34px] px-[20px] rounded-[10px] bg-gradient-to-r from-[#6D3BFF] to-[#4B22E8] text-white text-[11px] font-[600]">
                              Continue Learning
                            </button>
                          </div>
                        </div>
                      </div>

                      <!-- illustration -->
                      <div class="relative mr-[18px]">
                        <div class="w-[78px] h-[90px] rounded-t-full bg-[#FFCC80]"></div>
                      </div>

                    </div>
                  </div>
                </div>

                <!-- keyboard -->
                <div class="w-[530px] h-[18px] bg-[#D6D8E0] rounded-b-[20px] ml-[-28px] shadow-lg"></div>
              </div>

              <!-- cup -->
              <div class="absolute right-[70px] bottom-[18px]">
                <div class="relative w-[82px] h-[110px] bg-white rounded-b-[22px] rounded-t-[10px] shadow-lg border border-[#ececec]">
                  <div class="absolute right-[-18px] top-[28px] w-[28px] h-[40px] border-[8px] border-white rounded-full"></div>
                </div>
              </div>

            </div>

          </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="flex items-center justify-center px-[36px] py-[40px]">

          <div class="w-full max-w-[810px] bg-white rounded-[36px] border border-[#ECEAF5] shadow-card px-[60px] py-[52px]">

            <!-- icon -->
            <div class="flex justify-center">
              <div class="w-[112px] h-[112px] rounded-full bg-[#F0EAFF] flex items-center justify-center">
                <i class="fa-solid fa-lock text-[58px] text-[#5B34F2]"></i>
              </div>
            </div>

            <!-- title -->
            <div class="text-center mt-[26px]">
              <h2 class="text-[56px] leading-none font-[800] text-[#0D1733]">
                Login to Your Account
              </h2>

              <p class="mt-[22px] text-[21px] text-[#61687D] font-[500]">
                Enter your credentials to access your account
              </p>
            </div>

            <!-- form -->
            <div class="mt-[52px]">

              <!-- email -->
              <div>
                <label class="block text-[20px] font-[700] text-[#111827] mb-[14px]">
                  Email Address
                </label>

                <div class="h-[72px] border border-[#DDE1EB] rounded-[14px] flex items-center px-[20px]">
                  <i class="fa-regular fa-envelope text-[24px] text-[#6C7388]"></i>

                  <input
                    type="email"
                    placeholder="Enter your email address"
                    class="flex-1 h-full px-[18px] outline-none text-[24px] text-[#111827] placeholder:text-[#8C93A6] bg-transparent"
                  />
                </div>
              </div>

              <!-- password -->
              <div class="mt-[36px]">
                <label class="block text-[20px] font-[700] text-[#111827] mb-[14px]">
                  Password
                </label>

                <div class="h-[72px] border border-[#DDE1EB] rounded-[14px] flex items-center px-[20px]">
                  <i class="fa-solid fa-lock text-[22px] text-[#6C7388]"></i>

                  <input
                    type="password"
                    placeholder="Enter your password"
                    class="flex-1 h-full px-[18px] outline-none text-[24px] text-[#111827] placeholder:text-[#8C93A6] bg-transparent"
                  />

                  <i class="fa-regular fa-eye text-[24px] text-[#6C7388]"></i>
                </div>
              </div>

              <!-- remember -->
              <div class="mt-[28px] flex items-center justify-between">
                <label class="flex items-center gap-[14px] cursor-pointer">
                  <input type="checkbox" class="w-[24px] h-[24px] rounded border-[#B9BED0]"/>
                  <span class="text-[18px] text-[#4C5469] font-[500]">
                    Remember me
                  </span>
                </label>

                <a href="#" class="text-[18px] font-[700] text-[#5B34F2]">
                  Forgot Password?
                </a>
              </div>

              <!-- login button -->
              <button class="mt-[34px] w-full h-[78px] rounded-[14px] bg-gradient-to-r from-[#6D3BFF] to-[#4B22E8] text-white text-[34px] font-[700] shadow-lg">
                Login
              </button>

              <!-- divider -->
              <div class="flex items-center gap-[24px] mt-[44px]">
                <div class="flex-1 h-[1px] bg-[#DDE1EB]"></div>

                <span class="text-[18px] text-[#525B71] font-[500]">
                  or login with
                </span>

                <div class="flex-1 h-[1px] bg-[#DDE1EB]"></div>
              </div>

              <!-- social -->
              <div class="grid grid-cols-2 gap-[28px] mt-[34px]">

                <button class="h-[78px] border border-[#DDE1EB] rounded-[14px] flex items-center justify-center gap-[18px] bg-white">
                  <div class="w-[34px] h-[34px] rounded-full bg-white flex items-center justify-center">
                    <i class="fa-brands fa-google text-[34px]" style="color:#EA4335"></i>
                  </div>

                  <span class="text-[20px] font-[500] text-[#1F2937]">
                    Continue with Google
                  </span>
                </button>

                <button class="h-[78px] border border-[#DDE1EB] rounded-[14px] flex items-center justify-center gap-[18px] bg-white">
                  <i class="fa-brands fa-facebook text-[36px] text-[#1877F2]"></i>

                  <span class="text-[20px] font-[500] text-[#1F2937]">
                    Continue with Facebook
                  </span>
                </button>

              </div>

              <!-- register -->
              <div class="text-center mt-[54px]">
                <span class="text-[18px] text-[#525B71] font-[500]">
                  Don’t have an account?
                </span>

                <a href="#" class="ml-[8px] text-[18px] font-[700] text-[#5B34F2]">
                  Register here
                </a>
              </div>

            </div>

          </div>

        </div>

      </div>

    </div>

  </div>

</body>
</html>
